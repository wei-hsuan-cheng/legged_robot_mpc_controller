<mujoco model="slope_5deg">
  <!-- 5 degree ramp along +x (height rises as x increases). -->
  <worldbody>
    <body name="slope" pos="-3 0 0">
      <!-- Rotate around Y by 5 deg: quat = [cos(2.5deg), 0, sin(2.5deg), 0] -->
      <geom name="slope_ramp"
            type="box"
            size="2.0 1.0 0.05"
            pos="0 0 0.05"
            quat="0.999048 0 0.043619 0"
            rgba="0.55 0.6 0.65 1"
            friction="0.8 0.1 0.001"/>
    </body>
  </worldbody>
</mujoco>
