<mujoco model="g1_scene">
  <include file="g1_29dof.xml"/>
  <!-- <include file="boxes.xml"/> -->
  <!-- <include file="stairs.xml"/>
  <include file="slope.xml"/> -->

  <!-- Match the legacy whole-body MuJoCo simulation timestep. -->
  <option timestep="0.0005"/>

  <statistic center="1.0 0.7 1.0" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0.9 0.9 0.9"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb2="0.835 0.761 0.612" rgb1="0.639 0.722 0.8" width="512" height="512"/>

    <texture type="2d" name="groundplane" builtin="checker" mark="random" 
         rgb1="0.25 0.3 0.35" rgb2="0.15 0.2 0.25" 
         markrgb="0.6 0.7 0.8" 
         width="512" height="512"/>

    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="2 2" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light pos="1 0 3.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>

</mujoco>
