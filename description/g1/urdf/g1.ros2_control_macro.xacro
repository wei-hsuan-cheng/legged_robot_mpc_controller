<?xml version="1.0"?>
<robot name="g1_ros2_control_macros" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro
    name="g1_joint_ros2_control"
    params="
      joint_name
      use_mujoco_sim
      joint_init
      command_interface:=effort
      effort_limit:=100.0
      effort_pd_kp:=1200.0
      effort_pd_kd:=10.0
      mujoco_position_kp:=10000
      mujoco_position_ki:=50
      mujoco_position_kd:=500
      mujoco_position_i_max:=10000
      mujoco_position_i_min:=-10000">
    <joint name="${joint_name}">
      <xacro:if value="${command_interface == 'effort_pd'}">
        <param name="effort_pd">true</param>
        <param name="effort_pd_kp">${effort_pd_kp}</param>
        <param name="effort_pd_kd">${effort_pd_kd}</param>
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort">
          <param name="min">${-effort_limit}</param>
          <param name="max">${effort_limit}</param>
        </command_interface>
      </xacro:if>
      <xacro:if value="${command_interface == 'effort'}">
        <command_interface name="effort">
          <param name="min">${-effort_limit}</param>
          <param name="max">${effort_limit}</param>
        </command_interface>
      </xacro:if>
      <xacro:unless value="${command_interface == 'effort' or command_interface == 'effort_pd'}">
        <xacro:if value="${use_mujoco_sim}">
          <param name="position_kp">${mujoco_position_kp}</param>
          <param name="position_ki">${mujoco_position_ki}</param>
          <param name="position_kd">${mujoco_position_kd}</param>
          <param name="position_i_max">${mujoco_position_i_max}</param>
          <param name="position_i_min">${mujoco_position_i_min}</param>
          <command_interface name="position_pid"/>
        </xacro:if>
        <xacro:unless value="${use_mujoco_sim}">
          <command_interface name="position"/>
        </xacro:unless>
      </xacro:unless>
      <state_interface name="position">
        <param name="initial_value">${joint_init[joint_name]}</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="effort"/>
    </joint>
  </xacro:macro>

  <xacro:macro
    name="g1_ros2_control"
    params="
      use_fake_hardware
      use_mujoco_sim
      joint_init
      system_name:=G1System
      command_interface:=effort
      effort_pd_kp:=1200.0
      effort_pd_kd:=10.0
      mujoco_position_kp:=10000
      mujoco_position_ki:=50
      mujoco_position_kd:=500
      mujoco_position_i_max:=10000
      mujoco_position_i_min:=-10000
      mujoco_effort_command_mode:=actuator">
    <ros2_control name="${system_name}" type="system">
      <hardware>
        <xacro:if value="${use_mujoco_sim}">
          <plugin>mujoco_ros2_control/MujocoSystem</plugin>
          <!-- 'actuator' drives the MuJoCo motors through ctrl (actuatorfrcrange limits apply,
               legacy WB simulator behavior); 'qfrc_applied' bypasses the actuators and injects
               the unclamped PD torque directly as a generalized force. -->
          <param name="mujoco_effort_command_mode">${mujoco_effort_command_mode}</param>
        </xacro:if>
        <xacro:unless value="${use_mujoco_sim}">
          <xacro:if value="${use_fake_hardware}">
            <plugin>mock_components/GenericSystem</plugin>
            <param name="mock_sensor_commands">false</param>
            <param name="calculate_dynamics">true</param>
            <param name="position_state_following_offset">0.0</param>
          </xacro:if>
        </xacro:unless>
      </hardware>

      <xacro:if value="${use_mujoco_sim}">
        <sensor name="pelvis">
          <param name="mujoco_body_name">pelvis</param>
          <state_interface name="position.x"/>
          <state_interface name="position.y"/>
          <state_interface name="position.z"/>
          <state_interface name="orientation.w"/>
          <state_interface name="orientation.x"/>
          <state_interface name="orientation.y"/>
          <state_interface name="orientation.z"/>
          <state_interface name="linear_velocity.x"/>
          <state_interface name="linear_velocity.y"/>
          <state_interface name="linear_velocity.z"/>
          <state_interface name="angular_velocity.x"/>
          <state_interface name="angular_velocity.y"/>
          <state_interface name="angular_velocity.z"/>
        </sensor>
      </xacro:if>

      <xacro:g1_joint_ros2_control
        joint_name="left_hip_pitch_joint"
        use_mujoco_sim="${use_mujoco_sim}"
        joint_init="${joint_init}"
        command_interface="${command_interface}"
        effort_pd_kp="${effort_pd_kp}"
        effort_pd_kd="${effort_pd_kd}"
        effort_limit="88"
        mujoco_position_kp="${mujoco_position_kp}"
        mujoco_position_ki="${mujoco_position_ki}"
        mujoco_position_kd="${mujoco_position_kd}"
        mujoco_position_i_max="${mujoco_position_i_max}"
        mujoco_position_i_min="${mujoco_position_i_min}"/>
      <xacro:g1_joint_ros2_control
        joint_name="left_hip_roll_joint"
        use_mujoco_sim="${use_mujoco_sim}"
        joint_init="${joint_init}"
        command_interface="${command_interface}"
        effort_pd_kp="${effort_pd_kp}"
        effort_pd_kd="${effort_pd_kd}"
        effort_limit="88"
        mujoco_position_kp="${mujoco_position_kp}"
        mujoco_position_ki="${mujoco_position_ki}"
        mujoco_position_kd="${mujoco_position_kd}"
        mujoco_position_i_max="${mujoco_position_i_max}"
        mujoco_position_i_min="${mujoco_position_i_min}"/>
      <xacro:g1_joint_ros2_control
        joint_name="left_hip_yaw_joint"
        use_mujoco_sim="${use_mujoco_sim}"
        joint_init="${joint_init}"
        command_interface="${command_interface}"
        effort_pd_kp="${effort_pd_kp}"
        effort_pd_kd="${effort_pd_kd}"
        effort_limit="88"
        mujoco_position_kp="${mujoco_position_kp}"
        mujoco_position_ki="${mujoco_position_ki}"
        mujoco_position_kd="${mujoco_position_kd}"
        mujoco_position_i_max="${mujoco_position_i_max}"
        mujoco_position_i_min="${mujoco_position_i_min}"/>
      <xacro:g1_joint_ros2_control
        joint_name="left_knee_joint"
        use_mujoco_sim="${use_mujoco_sim}"
        joint_init="${joint_init}"
        command_interface="${command_interface}"
        effort_pd_kp="${effort_pd_kp}"
        effort_pd_kd="${effort_pd_kd}"
        effort_limit="139"
        mujoco_position_kp="${mujoco_position_kp}"
        mujoco_position_ki="${mujoco_position_ki}"
        mujoco_position_kd="${mujoco_position_kd}"
        mujoco_position_i_max="${mujoco_position_i_max}"
        mujoco_position_i_min="${mujoco_position_i_min}"/>
      <xacro:g1_joint_ros2_control
        joint_name="left_ankle_pitch_joint"
        use_mujoco_sim="${use_mujoco_sim}"
        joint_init="${joint_init}"
        command_interface="${command_interface}"
        effort_pd_kp="${effort_pd_kp}"
        effort_pd_kd="${effort_pd_kd}"
        effort_limit="50"
