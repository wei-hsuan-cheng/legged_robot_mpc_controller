        command_interface="${command_interface}"
        effort_pd_kp="${effort_pd_kp}"
        effort_pd_kd="${effort_pd_kd}"
        effort_limit="25"
        mujoco_position_kp="${mujoco_position_kp}"
        mujoco_position_ki="${mujoco_position_ki}"
