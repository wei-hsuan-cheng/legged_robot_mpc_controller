        effort_pd_kd="${effort_pd_kd}"
        effort_limit="50"
        mujoco_position_kp="${mujoco_position_kp}"
        mujoco_position_ki="${mujoco_position_ki}"
        mujoco_position_kd="${mujoco_position_kd}"
        mujoco_position_i_max="${mujoco_position_i_max}"
        mujoco_position_i_min="${mujoco_position_i_min}"/>
      <xacro:g1_joint_ros2_control
